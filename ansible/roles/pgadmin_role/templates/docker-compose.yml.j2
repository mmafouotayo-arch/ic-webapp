# ============================================================
# roles/pgadmin_role/templates/docker-compose.yml.j2
# Template Jinja2 pour déployer pgAdmin
# ============================================================

version: '3.8'

services:

  {{ pgadmin_service_name }}:
    image: {{ pgadmin_image }}
    container_name: {{ pgadmin_container_name }}
    restart: always
    ports:
      - "{{ pgadmin_port }}:80"
    environment:
      PGADMIN_DEFAULT_EMAIL: {{ pgadmin_email }}
      PGADMIN_DEFAULT_PASSWORD: {{ pgadmin_password }}
    volumes:
      - {{ pgadmin_data_dir }}/pgadmin:/var/lib/pgadmin
      - {{ pgadmin_data_dir }}/servers.json:/pgadmin4/servers.json
    networks:
      - {{ pgadmin_network_name }}

networks:
  {{ pgadmin_network_name }}:
    name: {{ pgadmin_network_name }}
    driver: bridge
